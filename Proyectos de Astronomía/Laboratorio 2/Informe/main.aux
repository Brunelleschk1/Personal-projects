\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Histograma de la distancia en sigmas entre las estrellas con P>0.7 de pertenecer a M41. Se observan distancias más grandes que en el anterior, (Fig.~\ref {DistSigmViejo}) pero se siguen teniendo muchas estrellas cercanas a lo esperado y solo unas cuantas por encima de los 5 sigmas, lo que significa que, a pesar de estar más diluido que el anterior, sigue siendo un cúmulo bien definido.}}{5}{figure.caption.9}\protected@file@percent }
\newlabel{SIGMANuevo}{{9}{5}{Histograma de la distancia en sigmas entre las estrellas con P>0.7 de pertenecer a M41. Se observan distancias más grandes que en el anterior, (Fig.~\ref {DistSigmViejo}) pero se siguen teniendo muchas estrellas cercanas a lo esperado y solo unas cuantas por encima de los 5 sigmas, lo que significa que, a pesar de estar más diluido que el anterior, sigue siendo un cúmulo bien definido}{figure.caption.9}{}}
\@writefile{toc}{\contentsline {section}{\numberline {5}Conclusiones}{5}{section.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Diagrama de probabilidad de pertenencia en función de cada estrella para el nuevo set de datos. Se observa a duras penas la diferencia entre la pertenencia más alta al cúmulo y las probabilidades inferiores. }}{5}{figure.caption.10}\protected@file@percent }
\newlabel{PertUNuevo}{{10}{5}{Diagrama de probabilidad de pertenencia en función de cada estrella para el nuevo set de datos. Se observa a duras penas la diferencia entre la pertenencia más alta al cúmulo y las probabilidades inferiores}{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces CMD del primer set de datos estudiado. Se puede evidenciar una población perteneciene casi exclusivamente perteneciente a La secuencia principal, algo que no es lo esperado cuando se trabaja con este método de optimización de parámetros.}}{6}{figure.caption.11}\protected@file@percent }
\newlabel{CMDViejo}{{11}{6}{CMD del primer set de datos estudiado. Se puede evidenciar una población perteneciene casi exclusivamente perteneciente a La secuencia principal, algo que no es lo esperado cuando se trabaja con este método de optimización de parámetros}{figure.caption.11}{}}
