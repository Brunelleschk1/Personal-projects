\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Distancia, en sigmas de la distribución, entre las estrellas encontradas por la función de optimización de parámetros. Una distancia tan baja supone que los elementos sí pertenecen todos al cúmulo, sin excepciones reales.}}{2}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{DistSigmViejo}{{1}{2}{Distancia, en sigmas de la distribución, entre las estrellas encontradas por la función de optimización de parámetros. Una distancia tan baja supone que los elementos sí pertenecen todos al cúmulo, sin excepciones reales}{figure.caption.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Gráfico de probabilidad de pertenencia en función de cada estrella. Se aprecia que la distribución es supremamente binaria. }}{2}{figure.caption.2}\protected@file@percent }
\newlabel{ProbPertViejo}{{2}{2}{Gráfico de probabilidad de pertenencia en función de cada estrella. Se aprecia que la distribución es supremamente binaria}{figure.caption.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces VPD del primer set de datos utilizado. Se puede observar una gran densidad de estrellas en el cúmulo, con muy poquitas por fuera con probabilidades de pertenencia mucho más bajas}}{3}{figure.caption.3}\protected@file@percent }
\newlabel{VPDViejoZOOM}{{3}{3}{VPD del primer set de datos utilizado. Se puede observar una gran densidad de estrellas en el cúmulo, con muy poquitas por fuera con probabilidades de pertenencia mucho más bajas}{figure.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Mapa de la ascención recta contra la declinación de cada elemento analizado. En anaranjado se muestran los pertenecientes al cúmulo, mostrando que, efectivamente, la mayoría se encuentran en una zona de alta densidad hacia el centro de la agrupación. }}{3}{figure.caption.4}\protected@file@percent }
\newlabel{RADecViejo}{{4}{3}{Mapa de la ascención recta contra la declinación de cada elemento analizado. En anaranjado se muestran los pertenecientes al cúmulo, mostrando que, efectivamente, la mayoría se encuentran en una zona de alta densidad hacia el centro de la agrupación}{figure.caption.4}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4}Resultados}{3}{section.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Diagrama de probabilidad de pertenencia en función de cada estrella para el nuevo set de datos en escala logarítmica. Una comparación al histograma sin esta escala se encuentra en el anexo. \ref {PertUNuevo}}}{3}{figure.caption.5}\protected@file@percent }
\newlabel{PertUNuevoLog}{{5}{3}{Diagrama de probabilidad de pertenencia en función de cada estrella para el nuevo set de datos en escala logarítmica. Una comparación al histograma sin esta escala se encuentra en el anexo. \ref {PertUNuevo}}{figure.caption.5}{}}
\citation{wiki}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces VPD de los miembros con P>0.7 de pertenecer al cúmulo. Se oberva una densidad mucho menor de estrellas que en (Fig.~\ref {VPDViejoZOOM}). Asimismo, se ve que ciertas estrellas dentro de la zona resaltada no tienen una probabilidad tan alta de pertenecer al cúmulo.}}{4}{figure.caption.6}\protected@file@percent }
\newlabel{VPDNuevoZOOM}{{6}{4}{VPD de los miembros con P>0.7 de pertenecer al cúmulo. Se oberva una densidad mucho menor de estrellas que en (Fig.~\ref {VPDViejoZOOM}). Asimismo, se ve que ciertas estrellas dentro de la zona resaltada no tienen una probabilidad tan alta de pertenecer al cúmulo}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces CMD del nuevo set de datos. Se observa una población mayoritariamente en la parte inicial de la secuencia principal, tal y como se esperaba al iniciar este laboratorio. Comparado al CMD viejo, se nota que los resultados cuadran con lo esperado. (Fig.~\ref {CMDViejo}) }}{4}{figure.caption.7}\protected@file@percent }
\newlabel{CMDNuevo}{{7}{4}{CMD del nuevo set de datos. Se observa una población mayoritariamente en la parte inicial de la secuencia principal, tal y como se esperaba al iniciar este laboratorio. Comparado al CMD viejo, se nota que los resultados cuadran con lo esperado. (Fig.~\ref {CMDViejo})}{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Diagrama de declinación contra ascención recta. Comparado a (Fig.~\ref {RADecViejo}), se observa una zona diagonal dibujada, a comparación de la densidad central que se diluye hacia los bordes. Esto significa que nuestro cúmulo es ahora mucho más pequeño y menos definido. }}{4}{figure.caption.8}\protected@file@percent }
\newlabel{RADECNuevo}{{8}{4}{Diagrama de declinación contra ascención recta. Comparado a (Fig.~\ref {RADecViejo}), se observa una zona diagonal dibujada, a comparación de la densidad central que se diluye hacia los bordes. Esto significa que nuestro cúmulo es ahora mucho más pequeño y menos definido}{figure.caption.8}{}}
